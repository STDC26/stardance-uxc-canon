{
  "registry": "theme_registry",
  "version": "1.0.1",
  "uxc_version": "1.0.1",
  "date": "2026-05-05",
  "description": "All themes, modes, token references and tooltip rules. Activation Surface reads this for UIS compliance validation.",

  "uis_rules": {
    "grid_rule": "Theme count must equal mode count",
    "canonical_grid": "3x3",
    "default_theme": "vega",
    "default_mode": "vibe",
    "naming_convention": "Astronomical — one naming system per product",
    "hover_requirement": "Theme buttons must accent to primary colour on hover",
    "tooltip_positioning": "above button · left-anchored · extends rightward · white-space:nowrap · text-transform:none",
    "vanilla_policy": "Vanilla is a UXC violation",
    "creative_mandate": {
      "requirement": "3 of 4 criteria required for operator-facing and creator-facing surfaces",
      "criteria": ["Motion", "Depth", "Character", "Memory"]
    }
  },

  "modes": {
    "vibe": {
      "label": "Vibe",
      "css_key": "vibe",
      "deprecated_alias": "classic",
      "tooltip": "Amber glow · ideas first",
      "character": "Warm · editorial · creative",
      "status": "canonical",
      "version_added": "1.0.0",
      "key_updated": "1.0.1"
    },
    "dark": {
      "label": "Dark",
      "css_key": "dark",
      "tooltip": "Night sky · pure signal",
      "character": "Operator · high contrast · low-light",
      "status": "canonical",
      "version_added": "1.0.0"
    },
    "light": {
      "label": "Light",
      "css_key": "light",
      "tooltip": "Full spectrum · nothing hidden",
      "character": "Open · full visibility · review",
      "status": "canonical",
      "version_added": "1.0.0"
    },
    "classic": {
      "label": "DEPRECATED",
      "css_key": "classic",
      "status": "deprecated",
      "deprecated_in": "1.0.1",
      "replaced_by": "vibe",
      "note": "Alias layer maintained for backward compatibility only. No surface may depend on classic as canonical key after v1.0.1."
    }
  },

